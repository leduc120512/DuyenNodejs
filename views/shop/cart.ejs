<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Giỏ hàng - Shop thương mại điện tử</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <div class="container">

    
    <% if (cart.length === 0) { %>
      <p class="empty-cart">Giỏ hàng của bạn đang trống. <a href="/products">Tiếp tục mua sắm</a></p>
    <% } else { %>
      <table class="cart-table">
        <thead>
          <tr>
            <th>Sản phẩm</th>
            <th>Giá</th>
            <th>Số lượng</th>
            <th>Tạm tính</th>
            <th>Thao tác</th>
          </tr>
        </thead>
        <tbody>
          <% cart.forEach(item => { %>
            <tr>
              <td>
                <div class="cart-product">
                  <img src="<%= item.image %>" alt="<%= item.name %>">
                  <span><%= item.name %></span>
                </div>
              </td>
              <td><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(Number(item.price || 0)) %></td>
              <td>
                <form action="/cart/update" method="POST" class="quantity-form">
                  <input type="hidden" name="productId" value="<%= item.productId %>">
                  <input type="number" name="quantity" value="<%= item.quantity %>" min="1">
                  <button type="submit" class="btn btn-sm btn-secondary">Cập nhật</button>
                </form>
              </td>
              <td><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(Number(item.price * item.quantity || 0)) %></td>
              <td>
                <form action="/cart/remove" method="POST">
                  <input type="hidden" name="productId" value="<%= item.productId %>">
                  <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                </form>
              </td>
            </tr>
          <% }) %>
          <tr class="total-row">
            <td colspan="3"><strong>Tổng cộng</strong></td>
            <td colspan="2"><strong><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(Number(total || 0)) %></strong></td>
          </tr>
        </tbody>
      </table>
      
      <div class="cart-actions">
        <a href="/products" class="btn btn-secondary">Tiếp tục mua sắm</a>
        <a href="/checkout" class="btn btn-primary">Tiến hành thanh toán</a>
      </div>
    <% } %>
  </div>
</body>
</html>

