<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Products - Shop thương mại điện tử</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <div class="container">
    <% if (categories && categories.length) { %>
      <section style="margin: 24px 0;">
        <h2 style="margin-bottom: 12px;">Search by Category</h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:14px;">
          <a href="/products" style="text-decoration:none;color:#222;border:1px solid #ddd;border-radius:10px;overflow:hidden;background:#fff;">
            <img src="/images/default-product.jpg" alt="All categories" style="width:100%;height:110px;object-fit:cover;display:block;" onerror="this.onerror=null;this.src='/images/default-product.jpg';">
            <div style="padding:8px 10px;font-weight:600;text-align:center;">All</div>
          </a>

          <% categories.forEach(category => { %>
            <a href="/products?category=<%= category._id %>" style="text-decoration:none;color:#222;border:1px solid #ddd;border-radius:10px;overflow:hidden;background:#fff;">
              <img src="<%= category.image || '/images/default-product.jpg' %>" alt="<%= category.name %>" style="width:100%;height:110px;object-fit:cover;display:block;" onerror="this.onerror=null;this.src='/images/default-product.jpg';">
              <div style="padding:8px 10px;font-weight:600;text-align:center;"><%= category.name %></div>
            </a>
          <% }) %>
        </div>
      </section>
    <% } %>

    <div class="product-grid">
      <% products.forEach(product => { %>
        <% 
          const isOutOfStock = product.stock <= 0;
          const cardUrl = isOutOfStock ? '#' : '/products/' + product._id;
          const cardClass = isOutOfStock ? 'product-card sold-out' : 'product-card';
        %>
        <a href="<%= cardUrl %>" class="<%= cardClass %>">
          <div style="position:relative;display:inline-block;width:100%;">
            <img src="<%= (product.images && product.images.length ? product.images[0] : product.image) || '/images/default-product.jpg' %>" alt="<%= product.name %>" onerror="this.onerror=null;this.src='/images/default-product.jpg';">
            <% if (isOutOfStock) { %>
              <div style="position:absolute;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;border-radius:8px;">
                <span style="color:white;font-weight:700;font-size:20px;text-transform:uppercase;letter-spacing:1px;">Hết Hàng</span>
              </div>
            <% } %>
          </div>
          <h3><%= product.name %></h3>
          <p class="category"><%= product.category ? product.category.name : 'No Category' %></p>

          <p class="price">$<%= product.price.toFixed(2) %></p>
          <p class="stock"><%= isOutOfStock ? 'Hết hàng' : 'Còn hàng: ' + product.stock %></p>
        </a>
      <% }) %>
    </div>
  </div>
</body>
</html>

