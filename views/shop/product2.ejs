<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <div class="container">
      <div class="product-grid">
        <% products.forEach(product => { %>
        <a href="/products/<%= product._id %>" class="product-card" style="display:block;text-decoration:none;color:inherit;">
          <img src="<%= product.image %>" alt="<%= product.name %>" />
          <h3><%= product.name %></h3>
          <p class="category">
            <%= product.category ? product.category.name : 'Chưa có danh mục' %>
          </p>

          <p class="price"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(Number(product.price || 0)) %></p>
          <p class="stock">Còn hàng: <%= product.stock %></p>
        </a>
        <% }) %>
      </div>
    </div>
  </body>
</html>
