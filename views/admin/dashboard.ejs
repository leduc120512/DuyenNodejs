<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - Fan Shop</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <div class="container">

    
    <div class="dashboard-stats">
      <div class="stat-card">
        <h3>Total Products</h3>
        <p class="stat-number"><%= productCount %></p>
      </div>
      <div class="stat-card">
        <h3>Categories</h3>
        <p class="stat-number"><%= categoryCount %></p>
      </div>
      <div class="stat-card">
        <h3>Total Orders</h3>
        <p class="stat-number"><%= orderCount %></p>
      </div>
      <div class="stat-card">
        <h3>Pending Orders</h3>
        <p class="stat-number"><%= pendingOrders %></p>
      </div>
    </div>
    
    <div class="dashboard-actions">
      <a href="/admin/products" class="btn btn-primary">Manage Products</a>
      <a href="/admin/categories" class="btn btn-primary">Manage Categories</a>
      <a href="/admin/orders" class="btn btn-primary">Manage Orders</a>
        <a href="/admin/users" class="btn btn-primary">Manage User</a>
    </div>
  </div>
</body>
</html>
