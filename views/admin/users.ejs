<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Users - Fan Shop</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <div class="container">
    <div class="page-header">
      <h1>Manage Users</h1>
    </div>
    
    <form action="/admin/users" method="GET" class="search-form">
      <input type="text" name="search" placeholder="Search by username, email, full name..." value="<%= search %>">
      
      <select name="status">
        <option value="">All Status</option>
        <option value="active" <%= status === 'active' ? 'selected' : '' %>>Active</option>
        <option value="inactive" <%= status === 'inactive' ? 'selected' : '' %>>Inactive</option>
        <option value="banned" <%= status === 'banned' ? 'selected' : '' %>>Banned</option>
        <option value="locked" <%= status === 'locked' ? 'selected' : '' %>>Locked (login attempts)</option>
      </select>
      
      <button type="submit" class="btn btn-secondary">Filter</button>
    </form>
    
    <table class="data-table">
      <thead>
        <tr>
          <th>Username</th>
          <th>Email</th>
          <th>Full Name</th>
          <th>Role</th>
          <th>Status</th>
          <th>Login Attempts</th>
          <th>Created</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(user => { %>
          <tr>
            <td><%= user.username %></td>
            <td><%= user.email %></td>
            <td><%= user.fullName || '-' %></td>
            <td><%= user.role %></td>
            <td>
              <% if (user.isBanned) { %>
                <span class="status-badge danger">Banned</span>
              <% } else if (!user.isActive) { %>
                <span class="status-badge warning">Inactive</span>
              <% } else if (user.lockUntil && new Date(user.lockUntil) > new Date()) { %>
                <span class="status-badge danger">Locked</span>
              <% } else { %>
                <span class="status-badge success">Active</span>
              <% } %>
            </td>
            <td><%= user.loginAttempts || 0 %></td>
            <td><%= new Date(user.createdAt).toLocaleDateString() %></td>
            <td class="actions">
              <a href="/admin/users/<%= user._id %>" class="btn btn-sm btn-info">Detail</a>
              <a href="/admin/users/<%= user._id %>/manage" class="btn btn-sm btn-warning">Manage</a>
            </td>
          </tr>
        <% }) %>
        
        <% if (users.length === 0) { %>
          <tr>
            <td colspan="8" class="text-center">No users found</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</body>
</html>