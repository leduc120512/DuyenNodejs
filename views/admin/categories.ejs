<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quản lý danh mục - Shop thương mại điện tử</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="admin-shell">
    <%- include('../partials/admin-sidebar') %>
    <main class="admin-main">
      <div class="container">
    <div class="page-header">
      <h1>Quản lý danh mục</h1>
      <a href="/admin/categories/add" class="btn btn-primary">Thêm danh mục mới</a>
    </div>
    
    <form action="/admin/categories" method="GET" class="search-form">
      <input type="text" name="search" placeholder="Tìm danh mục..." value="<%= search %>">
      <button type="submit" class="btn btn-secondary">Tìm kiếm</button>
    </form>
    
    <table class="data-table">
      <thead>
        <tr>
          <th>Ảnh</th>
          <th>Tên</th>
          <th>Mô tả</th>
          <th>Thao tác</th>
        </tr>
      </thead>
      <tbody>
        <% categories.forEach(category => { %>
          <tr>
            <td>
              <img
                src="<%= category.image || '/images/default-product.jpg' %>"
                alt="<%= category.name %>"
                class="product-thumb"
              >
            </td>
            <td><%= category.name %></td>
            <td><%= category.description %></td>
            <td class="actions">
              <a href="/admin/categories/edit/<%= category._id %>" class="btn btn-sm btn-secondary">Sửa</a>
              <form action="/admin/categories/delete/<%= category._id %>" method="POST" style="display: inline;">
                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Bạn có chắc chắn không?')">Xóa</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
      </div>
    </main>
  </div>
</body>
</html>

