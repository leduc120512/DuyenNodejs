<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đăng ký - Shop thương mại điện tử</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page">
  <div class="auth-container">
    <div class="auth-box auth-box--register">
      <div class="auth-brand">Shop thuong mai dien tu</div>
      <h1>Đăng ký</h1>
      <p class="auth-subtitle">Tạo tài khoản mới để mua sắm nhanh hơn.</p>

      <!-- lá»—i chung -->
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <form action="/auth/register" method="POST">

        <!-- USERNAME -->
        <div class="form-group">
          <label for="username">Tên đăng nhập</label>
          <input 
            type="text" 
            id="username" 
            name="username" 
            value="<%= oldData?.username || '' %>"
            required
          >
          <% if (errors?.username) { %>
            <span class="form-error"><%= errors.username %></span>
          <% } %>
        </div>

        <!-- EMAIL -->
        <div class="form-group">
          <label for="email">Email</label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            value="<%= oldData?.email || '' %>"
            required
          >
          <% if (errors?.email) { %>
            <span class="form-error"><%= errors.email %></span>
          <% } %>
        </div>

        <!-- FULL NAME -->
        <div class="form-group">
          <label for="fullName">Họ và tên</label>
          <input 
            type="text" 
            id="fullName" 
            name="fullName" 
            value="<%= oldData?.fullName || '' %>"
            required
          >
          <% if (errors?.fullName) { %>
            <span class="form-error"><%= errors.fullName %></span>
          <% } %>
        </div>

        <!-- PHONE -->
        <div class="form-group">
          <label for="phone">Số điện thoại</label>
          <input 
            type="text" 
            id="phone" 
            name="phone" 
            value="<%= oldData?.phone || '' %>"
          >
        </div>

        <!-- ADDRESS -->
        <div class="form-group">
          <label for="address">Địa chỉ</label>
          <textarea 
            id="address" 
            name="address" 
            rows="3"
          ><%= oldData?.address || '' %></textarea>
        </div>

        <!-- PASSWORD -->
        <div class="form-group">
          <label for="password">Mật khẩu</label>
          <input 
            type="password" 
            id="password" 
            name="password" 
            autocomplete="new-password"
            required
          >
          <% if (errors?.password) { %>
            <span class="form-error"><%= errors.password %></span>
          <% } %>
        </div>

        <!-- CONFIRM PASSWORD -->
        <div class="form-group">
          <label for="confirmPassword">Xác nhận mật khẩu</label>
          <input 
            type="password" 
            id="confirmPassword" 
            name="confirmPassword" 
            autocomplete="new-password"
            required
          >
          <% if (errors?.confirmPassword) { %>
            <span class="form-error"><%= errors.confirmPassword %></span>
          <% } %>
        </div>

        <button type="submit" class="btn btn-primary">Đăng ký</button>
      </form>

      <p class="auth-link">
        Đã có tài khoản? 
        <a href="/auth/login">Đăng nhập tại đây</a>
      </p>
    </div>
  </div>
</body>
</html>
