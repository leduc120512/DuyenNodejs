<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register - Shop thương mại điện tử</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="auth-container">
    <div class="auth-box">
      <h1>Register</h1>

      <!-- lá»—i chung -->
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <form action="/auth/register" method="POST">

        <!-- USERNAME -->
        <div class="form-group">
          <label for="username">Username</label>
          <input 
            type="text" 
            id="username" 
            name="username" 
            value="<%= oldData?.username || '' %>"
            required
          >
          <% if (errors?.username) { %>
            <span class="form-error"><%= errors.username %></span>
          <% } %>
        </div>

        <!-- EMAIL -->
        <div class="form-group">
          <label for="email">Email</label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            value="<%= oldData?.email || '' %>"
            required
          >
          <% if (errors?.email) { %>
            <span class="form-error"><%= errors.email %></span>
          <% } %>
        </div>

        <!-- FULL NAME -->
        <div class="form-group">
          <label for="fullName">Full Name</label>
          <input 
            type="text" 
            id="fullName" 
            name="fullName" 
            value="<%= oldData?.fullName || '' %>"
            required
          >
          <% if (errors?.fullName) { %>
            <span class="form-error"><%= errors.fullName %></span>
          <% } %>
        </div>

        <!-- PHONE -->
        <div class="form-group">
          <label for="phone">Phone</label>
          <input 
            type="text" 
            id="phone" 
            name="phone" 
            value="<%= oldData?.phone || '' %>"
          >
        </div>

        <!-- ADDRESS -->
        <div class="form-group">
          <label for="address">Address</label>
          <textarea 
            id="address" 
            name="address" 
            rows="3"
          ><%= oldData?.address || '' %></textarea>
        </div>

        <!-- PASSWORD -->
        <div class="form-group">
          <label for="password">Password</label>
          <input 
            type="password" 
            id="password" 
            name="password" 
            autocomplete="new-password"
            required
          >
          <% if (errors?.password) { %>
            <span class="form-error"><%= errors.password %></span>
          <% } %>
        </div>

        <!-- CONFIRM PASSWORD -->
        <div class="form-group">
          <label for="confirmPassword">Confirm Password</label>
          <input 
            type="password" 
            id="confirmPassword" 
            name="confirmPassword" 
            autocomplete="new-password"
            required
          >
          <% if (errors?.confirmPassword) { %>
            <span class="form-error"><%= errors.confirmPassword %></span>
          <% } %>
        </div>

        <button type="submit" class="btn btn-primary">Register</button>
      </form>

      <p class="auth-link">
        Already have an account? 
        <a href="/auth/login">Login here</a>
      </p>
    </div>
  </div>
</body>
</html>
