<!-- SCRIPT - Giá»¯ nguyÃªn nhÆ° láº§n trÆ°á»›c, Ä‘Ã£ cÃ³ debug log -->
<script>
  document.addEventListener("DOMContentLoaded", function () {
    const input = document.getElementById("search-input");
    const searchBtn = document.querySelector(".search-wrapper button");
    const suggestBox = document.getElementById("ai-suggest-box");
    let debounceTimer = null;
    let clearConfirmMode = false;

    if (!input || !suggestBox) {
      console.error("Element missing");
      return;
    }

    function escapeHtml(value = "") {
      return String(value)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/\"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    function runKeywordSearch(keyword) {
      const q = String(keyword || "").trim();
      if (!q) return;
      window.location.href = `/products?search=${encodeURIComponent(q)}`;
    }

    async function deleteOneKeyword(keyword) {
      const q = String(keyword || "").trim();
      if (!q) return;

      const res = await fetch(
        `/api/ai-search/history?keyword=${encodeURIComponent(q)}`,
        {
          method: "DELETE",
        }
      );

      if (!res.ok) {
        throw new Error(`Delete API ${res.status}`);
      }
    }

    async function clearAllKeywords() {
      const res = await fetch(`/api/ai-search/history/all`, {
        method: "DELETE",
      });

      if (!res.ok) {
        throw new Error(`Clear API ${res.status}`);
      }
    }

    async function loadSuggest(keyword = "") {
      try {
        const res = await fetch(
          `/api/ai-search/history?q=${encodeURIComponent(keyword)}`
        );
        if (!res.ok) throw new Error(`API ${res.status}`);
        const data = await res.json();
        const suggestions = Array.isArray(data?.suggestions)
          ? data.suggestions
          : [];

        if (!suggestions.length) {
          suggestBox.style.display = "none";
          return;
        }

        const hasSearchSuggestions = suggestions.some(
          (item) => item.type === "search"
        );

        const headerHtml = hasSearchSuggestions
          ? `<div class="suggest-actions">
               <div class="suggest-actions-title">Goi y gan day</div>
               <div class="suggest-actions-right">
                 ${
                   clearConfirmMode
                     ? `<button type="button" class="suggest-confirm-btn" data-role="cancel-clear">Huy</button>
                        <button type="button" class="suggest-confirm-btn confirm" data-role="confirm-clear">Xac nhan xoa</button>`
                     : `<button type="button" class="suggest-clear" data-role="clear-all">Xoa tat ca</button>`
                 }
               </div>
             </div>`
          : "";

        const listHtml = suggestions
          .map(
            (item) => `
          <div
            class="suggest-item"
            data-type="${escapeHtml(item.type || "search") }"
            data-keyword="${escapeHtml(item.keyword || "") }"
            data-product-id="${escapeHtml(item.product?._id || "") }"
          >
            <img src="${item.product?.image || "/images/no-image.png"}" alt="${escapeHtml(item.product?.name || item.keyword || "goi y")}">
            <div class="suggest-info">
              <div class="suggest-topline">
                <span class="suggest-badge ${
                  item.type === "viewed" ? "badge-viewed" : "badge-search"
                }">${item.type === "viewed" ? "Da xem" : "Lich su tim kiem"}</span>
                <div class="suggest-name">${
                  item.type === "viewed"
                    ? escapeHtml(item.product?.name || "San pham da xem")
                    : escapeHtml(item.keyword || "")
                }</div>
              </div>
              <div class="suggest-price">${
                item.product?.name
                  ? escapeHtml(item.product.name)
                  : "Tu khoa da tim gan day"
              }</div>
              <div class="suggest-meta">${
                item.type === "viewed"
                  ? "Mo lai san pham da xem"
                  : "Nhan de tim lai tu khoa"
              }</div>
            </div>
            ${
              item.type === "search"
                ? `<button type="button" class="suggest-remove" data-role="remove-keyword" data-keyword="${escapeHtml(
                    item.keyword || ""
                  )}">X</button>`
                : ""
            }
          </div>
        `
          )
          .join("");

        suggestBox.innerHTML = `${headerHtml}${listHtml}`;

        if (!listHtml.trim()) {
          suggestBox.innerHTML = `${headerHtml}<div class="suggest-empty-tip">Khong co du lieu goi y trong 7 ngay gan day</div>`;
        }

        suggestBox.style.display = "block";
      } catch (err) {
        console.error("Lá»—i:", err);
        suggestBox.style.display = "none";
      }
    }

    input.addEventListener("focus", () => {
      clearConfirmMode = false;
      loadSuggest(input.value);
    });
    input.addEventListener("input", () => {
      clearConfirmMode = false;
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        loadSuggest(input.value);
      }, 250);
    });

    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        runKeywordSearch(input.value);
      }
    });

    if (searchBtn) {
      searchBtn.addEventListener("click", (e) => {
        e.preventDefault();
        runKeywordSearch(input.value);
      });
    }

    suggestBox.addEventListener("click", async (event) => {
      const removeBtn = event.target.closest('[data-role="remove-keyword"]');
      if (removeBtn) {
        event.preventDefault();
        event.stopPropagation();

        const keyword = removeBtn.getAttribute("data-keyword") || "";
        try {
          await deleteOneKeyword(keyword);
          await loadSuggest(input.value);
        } catch (err) {
          console.error("Xoa keyword that bai:", err);
        }
        return;
      }

      const clearAllBtn = event.target.closest('[data-role="clear-all"]');
      if (clearAllBtn) {
        event.preventDefault();
        event.stopPropagation();

        clearConfirmMode = true;
        await loadSuggest(input.value);
        return;
      }

      const cancelClearBtn = event.target.closest('[data-role="cancel-clear"]');
      if (cancelClearBtn) {
        event.preventDefault();
        event.stopPropagation();

        clearConfirmMode = false;
        await loadSuggest(input.value);
        return;
      }

      const confirmClearBtn = event.target.closest('[data-role="confirm-clear"]');
      if (confirmClearBtn) {
        event.preventDefault();
        event.stopPropagation();

        try {
          await clearAllKeywords();
          clearConfirmMode = false;
          await loadSuggest(input.value);
        } catch (err) {
          console.error("Xoa toan bo lich su that bai:", err);
        }
        return;
      }

      const item = event.target.closest(".suggest-item");
      if (!item) return;

      const type = item.getAttribute("data-type") || "search";
      const keyword = item.getAttribute("data-keyword") || "";
      const productId = item.getAttribute("data-product-id") || "";

      suggestBox.style.display = "none";

      if (type === "viewed" && productId) {
        window.location.href = `/products/${encodeURIComponent(productId)}`;
        return;
      }

      input.value = keyword;
      runKeywordSearch(keyword);
    });

    document.addEventListener("click", (e) => {
      if (!e.target.closest(".search-wrapper")) {
        suggestBox.style.display = "none";
      }
    });
  });
</script>

