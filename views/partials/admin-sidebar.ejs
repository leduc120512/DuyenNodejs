<aside class="admin-sidebar">
  <% const activePath = typeof currentPath === 'string' ? currentPath : ''; %>
  <div class="admin-brand">
    <div class="admin-brand-mark">FS</div>
    <div>
      <div class="admin-brand-title">Quản trị thương mại điện tử</div>
      <div class="admin-brand-subtitle">Trung tâm điều khiển</div>
    </div>
  </div>

  <nav class="admin-nav">
    <div class="admin-nav-group">
      <div class="admin-nav-label">Tổng quan</div>
      <a
        href="/admin/dashboard"
        class="admin-nav-link <%= activePath === '/admin/dashboard' ? 'active' : '' %>"
      >
        Bảng điều khiển
      </a>
    </div>

    <div class="admin-nav-group">
      <div class="admin-nav-label">Quản lý</div>
      <a
        href="/admin/products"
        class="admin-nav-link <%= activePath.startsWith('/admin/products') ? 'active' : '' %>"
      >
        Sản phẩm
      </a>
      <a
        href="/admin/categories"
        class="admin-nav-link <%= activePath.startsWith('/admin/categories') ? 'active' : '' %>"
      >
        Danh mục
      </a>
      <a
        href="/admin/orders"
        class="admin-nav-link <%= activePath.startsWith('/admin/orders') ? 'active' : '' %>"
      >
        Đơn hàng
      </a>
      <a
        href="/admin/users"
        class="admin-nav-link <%= activePath.startsWith('/admin/users') ? 'active' : '' %>"
      >
        Người dùng
      </a>
      <a
        href="/admin/banners"
        class="admin-nav-link <%= activePath.startsWith('/admin/banners') ? 'active' : '' %>"
      >
        Banners
      </a>
    </div>

    <div class="admin-nav-group">
      <div class="admin-nav-label">Thao tác</div>
      <a href="/" class="admin-nav-link">Xem cửa hàng</a>
      <a href="/auth/logout" class="admin-nav-link danger">Đăng xuất</a>
    </div>
  </nav>

  <div class="admin-sidebar-footer">
    <div class="admin-user-chip">
      <span class="admin-user-avatar"
        ><%= (user && user.userName ? user.userName :
        'A').charAt(0).toUpperCase() %></span
      >
      <div>
        <div class="admin-user-name">
          <%= user && user.userName ? user.userName : 'Admin' %>
        </div>
        <div class="admin-user-role">
          <%= user && user.userRole ? user.userRole : 'admin' %>
        </div>
      </div>
    </div>
  </div>
</aside>
